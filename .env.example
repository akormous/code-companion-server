# Required environment variables for the backend server

# Full MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_user:your_password@your_cluster.mongodb.net/code-companion?retryWrites=true&w=majority

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# PORT is set automatically by Render — do NOT set this manually on Render
# PORT=3000
